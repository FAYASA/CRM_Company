@model Seashore_CRM.ViewModels.ProductGroup.ProGroupListViewModel

@{
    ViewData["Title"] = "Delete Product Group";
}

@await Html.PartialAsync("_PageHeader")

<div class="card mx-auto" style="max-width:800px;">
    <div class="card-body">
        <h3>Are you sure you want to delete this product group?</h3>
        <div class="mb-3">
            <h4>@Model.GroupName</h4>
            <p class="text-muted">Category: @Model.CategoryName</p>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-link">Cancel</a>
            </div>
        </form>
    </div>
</div>
