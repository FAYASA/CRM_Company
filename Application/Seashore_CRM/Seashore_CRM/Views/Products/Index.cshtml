@model IEnumerable<Seashore_CRM.ViewModels.Product.ProductViewModel>

@{
    ViewData["Title"] = "Products";
}

<h3>Products</h3>

<a asp-action="Create" class="btn btn-primary mb-3">+ New Product</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Product Name</th>
            <th>Category</th>
            <th>Product Group</th>
            <th>Cost</th>
            <th>Tax %</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.ProductName</td>
                <td>@p.CategoryName</td>
                <td>@p.ProductGroupName</td>
                <td>@p.Cost.ToString("0.00")</td>
                <td>@p.TaxPercentage.ToString("0.00")</td>
                <td>@(p.IsActive ? "Active" : "Inactive")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>