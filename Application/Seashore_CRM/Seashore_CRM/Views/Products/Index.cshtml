@model IEnumerable<Seashore_CRM.ViewModels.Product.ProductViewModel>

@{
    ViewData["Title"] = "Products";
}

<div class="container-fluid px-3">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center py-3">
        <div>
            <nav aria-label="breadcrumb" class="small mb-2">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a asp-action="Index" class="text-decoration-none">Home</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">Products</li>
                </ol>
            </nav>
            <h1 class="h4 fw-bold mb-0 text-dark">
                <i class="bi bi-box-seam me-2"></i> Products
                <span class="badge bg-light text-muted fw-normal ms-2 fs-6">
                    @Model.Count() total
                </span>
            </h1>
            <p class="small text-muted mb-0">
                Showing all products in the system
            </p>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Create" class="btn btn-danger btn-sm mb-2 px-3">
                <i class="bi bi-plus-lg me-1"></i> New Product
            </a>
        </div>
    </div>

    <!-- Products Table -->
    <div class="table-responsive">
        <table class="table table-striped table-hover table-bordered align-middle bg-white">
            <thead class="table-secondary small text-uppercase">
                <tr>
                    <th><i class="bi bi-tag me-1"></i> Product Name</th>
                    <th><i class="bi bi-diagram-3 me-1"></i> Category</th>
                    <th><i class="bi bi-collection me-1"></i> Product Group</th>
                    <th><i class="bi bi-currency-dollar me-1"></i> Cost</th>
                    <th><i class="bi bi-percent me-1"></i> Tax %</th>
                    <th><i class="bi bi-toggle-on me-1"></i> Status</th>
                    <th style="width:120px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td class="fw-semibold">
                            <a asp-action="Details" asp-route-id="@p.Id" class="text-decoration-none">
                                @p.ProductName
                            </a>
                        </td>
                        <td>
                            @{
                                var categories = p.Categories as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>;
                                if (categories == null || !categories.Any())
                                {
                                    @Html.Raw("<span class='text-muted'>N/A</span>")
                                }
                                else
                                {
                                    @string.Join(", ", categories.Select(c => c.Text))
                                }
                            }
                        </td>
                        <td>
                            @{
                                var productGroups = p.ProductGroups as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>;
                                if (productGroups == null || !productGroups.Any())
                                {
                                    @Html.Raw("<span class='text-muted'>N/A</span>")
                                }
                                else
                                {
                                    @string.Join(", ", productGroups.Select(pg => pg.Text))
                                }
                            }
                        </td>
                        <td>@p.Cost.ToString("0.00")</td>
                        <td>@($"{p.TaxPercentage:0.00}")</td>
                        <td>
                            @if (p.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm" role="group">
                                <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-outline-secondary" title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-outline-primary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>