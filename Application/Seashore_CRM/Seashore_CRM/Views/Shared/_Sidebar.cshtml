@using seashore_CRM.Common.Constants

<div class="app-sidebar d-flex flex-column bg-dark vh-100">
    <nav class="sidebar-nav px-2 flex-grow-1">
        <ul class="nav flex-column">

            <!-- Main Menu -->
            <li class="nav-item text-uppercase text-muted small mt-3">Main Menu</li>
            <li class="nav-item">
                <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                   asp-controller="Home" asp-action="Index">
                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                </a>
            </li>

            <!-- Companies -->
            <li class="nav-item">
                <a class="nav-link text-white d-flex justify-content-between align-items-center"
                   data-bs-toggle="collapse"
                   href="#companiesMenu"
                   aria-expanded="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Companies")">
                    <span><i class="bi bi-building me-2"></i> Companies</span>
                </a>

                <div class="collapse @(ViewContext.RouteData.Values["controller"]?.ToString() == "Companies" ? "show" : "")" id="companiesMenu">
                    <ul class="nav flex-column ms-3">
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                               asp-controller="Companies" asp-action="Index">
                                <i class="bi bi-list-ul me-2"></i> All Companies
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : "")"
                               asp-controller="Companies" asp-action="Create">
                                <i class="bi bi-plus-circle me-2"></i> Add Company
                            </a>
                        </li>
                    </ul>
                </div>
            </li>

            <!-- Contacts -->
            <li class="nav-item">
                <a class="nav-link text-white d-flex justify-content-between align-items-center"
                   data-bs-toggle="collapse"
                   href="#contactsMenu"
                   aria-expanded="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Contacts")">
                    <span><i class="bi bi-people me-2"></i> Contacts</span>
                </a>

                <div class="collapse @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contacts" ? "show" : "")" id="contactsMenu">
                    <ul class="nav flex-column ms-3">
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                               asp-controller="Contacts" asp-action="Index">
                                <i class="bi bi-list-ul me-2"></i> All Contacts
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : "")"
                               asp-controller="Contacts" asp-action="Create">
                                <i class="bi bi-person-plus-fill me-2"></i> Add Contact
                            </a>
                        </li>
                    </ul>
                </div>
            </li>

            <!-- Leads -->
            <li class="nav-item">
                <a class="nav-link text-white d-flex justify-content-between align-items-center"
                   data-bs-toggle="collapse"
                   href="#leadsMenu"
                   aria-expanded="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Leads")">
                    <span><i class="bi bi-person-lines-fill me-2"></i> Leads</span>
                </a>

                <div class="collapse @(ViewContext.RouteData.Values["controller"]?.ToString() == "Leads" ? "show" : "")" id="leadsMenu">
                    <ul class="nav flex-column ms-3">
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                               asp-controller="Leads" asp-action="Index">
                                <i class="bi bi-list-ul me-2"></i> All Leads
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : "")"
                               asp-controller="Leads" asp-action="Create">
                                <i class="bi bi-person-plus-fill me-2"></i> Lead Capture
                            </a>
                        </li>
                    </ul>
                </div>
            </li>

            <!-- Sales -->
            <li class="nav-item text-uppercase text-muted small mt-3">Sales</li>

            <li class="nav-item">
                <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Opportunities" ? "active" : "")"
                   asp-controller="Opportunities" asp-action="Index">
                    <i class="bi bi-briefcase me-2"></i> Opportunities
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Quotes" ? "active" : "")"
                   asp-controller="Quotes" asp-action="Index">
                    <i class="bi bi-card-text me-2"></i> Quotes
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contracts" ? "active" : "")"
                   asp-controller="Contracts" asp-action="Index">
                    <i class="bi bi-file-earmark-text me-2"></i> Contracts
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Invoices" ? "active" : "")"
                   asp-controller="Invoices" asp-action="Index">
                    <i class="bi bi-receipt me-2"></i> Invoices
                </a>
            </li>

            <!-- General -->
            <li class="nav-item text-uppercase text-muted small mt-3">General</li>

            <li class="nav-item">
                <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")"
                   asp-controller="Products" asp-action="Index">
                    <i class="bi bi-box-seam me-2"></i> Products
                </a>
            </li>

            <!-- Support -->
            <li class="nav-item text-uppercase text-muted small mt-3">Support</li>

            <li class="nav-item">
                <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tickets" ? "active" : "")"
                   asp-controller="Tickets" asp-action="Index">
                    <i class="bi bi-life-preserver me-2"></i> Tickets
                </a>
            </li>

            <!-- Analytics -->
            <li class="nav-item text-uppercase text-muted small mt-3">Analytics</li>

            <li class="nav-item">
                <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Analytics" ? "active" : "")"
                   asp-controller="Analytics" asp-action="Index">
                    <i class="bi bi-bar-chart-line me-2"></i> Reports
                </a>
            </li>

            <!-- Profile -->
            <li class="nav-item text-uppercase text-muted small mt-3">Account</li>

            <li class="nav-item">
                <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Profile" ? "active" : "")"
                   asp-controller="Profile" asp-action="Index">
                    <i class="bi bi-person-circle me-2"></i> Profile
                </a>
            </li>

            <!-- Admin Users -->
            @if (User?.IsInRole(RoleNames.Administrator) == true)
            {
                <li class="nav-item mt-3">
                    <a class="nav-link text-white d-flex justify-content-between align-items-center"
                       data-bs-toggle="collapse"
                       href="#usersMenu"
                       aria-expanded="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Users")">
                        <span><i class="bi bi-people-fill me-2"></i> Users</span>
                    </a>

                    <div class="collapse @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "show" : "")" id="usersMenu">
                        <ul class="nav flex-column ms-3">
                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="Users" asp-action="Index">
                                    <i class="bi bi-list-ul me-2"></i> All Users
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="Users" asp-action="Create">
                                    <i class="bi bi-person-plus-fill me-2"></i> Add User
                                </a>
                            </li>
                        </ul>
                    </div>
                </li>
            }

        </ul>
    </nav>
</div>