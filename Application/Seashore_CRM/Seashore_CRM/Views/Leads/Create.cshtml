@model seashore_CRM.Models.DTOs.LeadDto
@{
    ViewData["Title"] = "Lead Capture";
}

@await Html.PartialAsync("_PageHeader")

<form asp-action="Create" method="post" enctype="multipart/form-data" class="mt-3 pb-5">
    @Html.AntiForgeryToken()

    <!-- Pipeline progress bar -->
    <div class="mb-3">
        <div class="d-flex align-items-center">
            <div class="w-100">
                <ul class="list-inline mb-0 d-flex justify-content-between align-items-center" style="list-style:none;padding:0;margin:0;">
                    <li class="text-center flex-fill">
                        <div class="rounded-circle bg-primary text-white mx-auto" style="width:28px;height:28px;line-height:28px;">1</div>
                        <small class="d-block">Capture</small>
                    </li>
                    <li class="text-center flex-fill">
                        <div class="rounded-circle bg-primary text-white mx-auto" style="width:28px;height:28px;line-height:28px;">2</div>
                        <small class="d-block">Qualify</small>
                    </li>
                    <li class="text-center flex-fill">
                        <div class="rounded-circle bg-light text-muted mx-auto" style="width:28px;height:28px;line-height:28px;">3</div>
                        <small class="d-block">Develop</small>
                    </li>
                    <li class="text-center flex-fill">
                        <div class="rounded-circle bg-light text-muted mx-auto" style="width:28px;height:28px;line-height:28px;">4</div>
                        <small class="d-block">Propose</small>
                    </li>
                    <li class="text-center flex-fill">
                        <div class="rounded-circle bg-light text-muted mx-auto" style="width:28px;height:28px;line-height:28px;">5</div>
                        <small class="d-block">Close</small>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <div class="container-fluid px-0">
        <div class="card">
            <div class="card-body p-3">
                <ul class="nav nav-tabs mb-3" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link active" data-bs-toggle="tab" href="#summaryTab" role="tab">Summary</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#detailsTab" role="tab">Details</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#filesTab" role="tab">Files</a>
                    </li>
                </ul>

                <div class="tab-content">
                    <div class="tab-pane fade show active" id="summaryTab" role="tabpanel">
                        <div class="row g-4">
                            <div class="col-lg-4">
                                <!-- Contact card -->
                                <div class="card mb-3">
                                    <div class="card-header bg-white">Contact</div>
                                    <div class="card-body">
                                        <div class="mb-2">
                                            <label class="form-label small">Lead Topic</label>
                                            <input asp-for="QualificationNotes" class="form-control form-control-sm" />
                                        </div>
                                        <div class="row">
                                            <div class="col-6 mb-2">
                                                <label class="form-label small">First / Contact</label>
                                                <select asp-for="ContactId" class="form-select form-select-sm" asp-items="ViewBag.Contacts"></select>
                                            </div>
                                            <div class="col-6 mb-2">
                                                <label class="form-label small">Company</label>
                                                <select asp-for="CompanyId" class="form-select form-select-sm" asp-items="ViewBag.Companies"></select>
                                            </div>
                                        </div>

                                        <div class="row mt-2">
                                            <div class="col-12 mb-2">
                                                <label class="form-label small">Business Phone</label>
                                                <input type="text" class="form-control form-control-sm" />
                                            </div>
                                            <div class="col-12 mb-2">
                                                <label class="form-label small">Mobile Phone</label>
                                                <input type="text" class="form-control form-control-sm" />
                                            </div>
                                            <div class="col-12 mb-0">
                                                <label class="form-label small">Email</label>
                                                <input type="email" class="form-control form-control-sm" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Company card -->
                                <div class="card">
                                    <div class="card-header bg-white">Company</div>
                                    <div class="card-body">
                                        <div class="mb-2">
                                            <label class="form-label small">Company Name</label>
                                            <select asp-for="CompanyId" class="form-select form-select-sm" asp-items="ViewBag.Companies"></select>
                                        </div>
                                        <div class="mb-2">
                                            <label class="form-label small">Website</label>
                                            <input type="text" class="form-control form-control-sm" />
                                        </div>
                                        <div class="mb-0">
                                            <label class="form-label small">Address</label>
                                            <input type="text" class="form-control form-control-sm" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-4">
                                <!-- Up next -->
                                <div class="card mb-3">
                                    <div class="card-header bg-white">Up next</div>
                                    <div class="card-body text-muted">Upcoming activities will appear here</div>
                                </div>

                                <!-- Timeline -->
                                <div class="card mb-3">
                                    <div class="card-header bg-white">Timeline</div>
                                    <div class="card-body text-center text-muted" style="min-height:150px;">Almost there<br/><small>Select Save to see your timeline.</small></div>
                                </div>

                                <!-- Qualification quick actions -->
                                <div class="card">
                                    <div class="card-header bg-white">Qualification</div>
                                    <div class="card-body">
                                        <div class="form-check mb-2">
                                            <input asp-for="IsQualified" class="form-check-input" />
                                            <label asp-for="IsQualified" class="form-check-label">Qualified</label>
                                        </div>
                                        <div class="mb-2">
                                            <label class="form-label small">Budget</label>
                                            <input asp-for="Budget" class="form-control form-control-sm" />
                                        </div>
                                        <div class="mb-2">
                                            <label class="form-label small">Decision Date</label>
                                            <input asp-for="DecisionDate" class="form-control form-control-sm" type="date" />
                                        </div>
                                        <div>
                                            <label class="form-label small">Probability</label>
                                            <input asp-for="Probability" class="form-control form-control-sm" type="number" min="0" max="100" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-4">
                                <!-- Who Knows Whom -->
                                <div class="card mb-3">
                                    <div class="card-header bg-white">Who Knows Whom</div>
                                    <div class="card-body text-muted">No connections found</div>
                                </div>

                                <!-- Assistant -->
                                <div class="card mb-3">
                                    <div class="card-header bg-white">Assistant</div>
                                    <div class="card-body text-muted">This record hasn't been created yet. To enable this content, create the record.</div>
                                </div>

                                <!-- Quick details card -->
                                <div class="card">
                                    <div class="card-header bg-white">Quick Info</div>
                                    <div class="card-body">
                                        <p class="mb-1"><strong>Status:</strong> <span>@Model.StatusId</span></p>
                                        <p class="mb-0"><strong>Assigned To:</strong> <span>@Model.AssignedUserName</span></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="detailsTab" role="tabpanel">
                        <!-- Put detailed edit fields here (reuse existing form block) -->
                        <div class="row">
                            <div class="col-lg-8">
                                <div class="card mb-3">
                                    <div class="card-body">
                                        <!-- reuse the original general information block -->
                                        @* For brevity reuse existing inputs shown on capture area; full details can be added here as needed *@
                                        <div class="mb-3">
                                            <label class="form-label">Priority</label>
                                            <input asp-for="Priority" class="form-control form-control-sm" />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Attachments</label>
                                            <input type="file" name="files" class="form-control form-control-sm" multiple />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-4">
                                <div class="card">
                                    <div class="card-body">
                                        <p class="mb-1"><strong>Created:</strong> N/A</p>
                                        <p class="mb-0"><strong>Updated:</strong> @(Model.UpdatedDate?.ToString() ?? "N/A")</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="filesTab" role="tabpanel">
                        <div class="card">
                            <div class="card-body text-muted">Files will appear here once uploaded.</div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</form>

@section Scripts {
    @* Keep existing page scripts (product rows, activity mapping, AJAX contact load) *@
    <script>
        $(function(){
            // Initialize existing behaviors: load contacts, product rows, activities mapping etc.
            // Trigger existing handlers if present
            $('#companySelect').trigger('change');
            $('#statusSelect').trigger('change');
        });
    </script>
}