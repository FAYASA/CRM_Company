@using System.Text.Json
@using Seashore_CRM.ViewModels.Lead
@model Seashore_CRM.ViewModels.Lead.LeadCreateViewModel
@{
    ViewData["Title"] = Model.Mode == "edit" ? "Edit Lead" : "Lead Capture";
}

@await Html.PartialAsync("_PageHeader")

<form asp-action="@(Model.Mode == "edit" ? "Edit" : "Create")" method="post" enctype="multipart/form-data" class="mt-3 pb-5">
    @Html.AntiForgeryToken()
    <div class="container-fluid px-4">
        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
            <div>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm px-3 me-2">Cancel</a>
                <button type="submit" class="btn btn-primary btn-sm px-4 fw-bold shadow-sm">@Model.SubmitButtonText</button>
            </div>
        </div>

        @* include hidden Id when editing *@
        @if (Model.Mode == "edit")
        {
            <input type="hidden" asp-for="Lead.Id" />
            @if (Model.Lead?.RowVersion != null)
            {
                <input type="hidden" name="Lead.RowVersion" value="@System.Convert.ToBase64String(Model.Lead.RowVersion)" />
            }
        }

        <!-- Tabs Navigation -->
        <ul class="nav nav-tabs mb-3" id="leadTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="general-tab" data-bs-toggle="tab" data-bs-target="#generalTab" type="button" role="tab" aria-controls="generalTab" aria-selected="true">General Info</button>
            </li>

            <li class="nav-item" role="presentation">
                <button class="nav-link" id="product-tab" data-bs-toggle="tab" data-bs-target="#productTab" type="button" role="tab" aria-controls="productTab" aria-selected="false">Products</button>
            </li>

            <li class="nav-item" role="presentation">
                <button class="nav-link" id="Rights-tab" data-bs-toggle="tab" data-bs-target="#RightsTab" type="button" role="tab" aria-controls="RightsTab" aria-selected="false">View / Edit Rights</button>
            </li>

            <li class="nav-item" role="presentation">
                <button class="nav-link" id="comments-tab" data-bs-toggle="tab" data-bs-target="#commentsTab" type="button" role="tab" aria-controls="commentsTab" aria-selected="false">Comments & Notes</button>
            </li>
        </ul>

        <!-- Tabs Content -->
        <div class="tab-content" id="leadTabsContent">

            <!-- General Information Tab -->
            <div class="tab-pane fade show active" id="generalTab" role="tabpanel">

                <div class="card shadow-sm border-0 mb-4">

                    <div class="card-header bg-white py-3">
                        <h6 class="text-uppercase fw-bold text-secondary mb-0 small">
                            General Information
                        </h6>
                    </div>

                    <div class="card-body">

                        <div class="row g-4">

                            <!-- Lead Type -->
                            <div class="col-lg-3">
                                <label class="form-label fw-semibold small text-muted">Lead Type</label>

                                <div class="border rounded p-2 d-flex gap-3 align-items-center">

                                    <div class="form-check mb-0">
                                        <input class="form-check-input" type="radio" asp-for="Lead.LeadType" value="Corporate" id="leadCorporate">
                                        <label class="form-check-label small" for="leadCorporate">
                                            <i class="bi bi-building text-primary me-1"></i> Corporate
                                        </label>
                                    </div>

                                    <div class="form-check mb-0">
                                        <input class="form-check-input" type="radio" asp-for="Lead.LeadType" value="Individual" id="leadIndividual">
                                        <label class="form-check-label small" for="leadIndividual">
                                            <i class="bi bi-person text-success me-1"></i> Individual
                                        </label>
                                    </div>

                                </div>
                            </div>


                            <!-- Company -->
                            <div class="col-lg-3" id="companySelectDiv">
                                <label class="form-label fw-semibold small text-muted">
                                    Company
                                    <a asp-action="Create" asp-controller="Companies" target="_blank" class="ms-1 small text-primary">+ New</a>
                                </label>

                                <select asp-for="Lead.CompanyId"
                                        class="form-select form-select-sm"
                                        asp-items="Model.Companies"
                                        id="companySelect">

                                    <option value="">Select Company</option>

                                </select>
                            </div>


                            <!-- Corporate Contact -->
                            <div class="col-lg-3" id="corporateContactDiv">

                                <label class="form-label fw-semibold small text-muted">
                                    Contact
                                    <a asp-action="Create" asp-controller="Contacts" target="_blank" class="ms-1 small text-primary">+ New</a>
                                </label>

                                <select asp-for="Lead.ContactId"
                                        class="form-select form-select-sm"
                                        asp-items="Model.Contacts"
                                        id="corporateContactSelect">

                                    <option value="">Select Contact</option>

                                </select>

                            </div>


                            <!-- Individual Contact -->
                            <div class="col-lg-3" id="individualContactDiv" style="display:none;">

                                <label class="form-label fw-semibold small text-muted">
                                    Individual Contact
                                    <a href="#" class="ms-1 small text-primary" data-bs-toggle="modal" data-bs-target="#createContactModal">
                                        + New
                                    </a>
                                </label>

                                <select asp-for="Lead.ContactId"
                                        class="form-select form-select-sm"
                                        asp-items="Model.ContactForIndv"
                                        id="individualContactSelect">

                                    <option value="">Select Contact</option>

                                </select>

                            </div>


                            <!-- Source -->
                            <div class="col-lg-3">

                                <label class="form-label fw-semibold small text-muted">Source</label>

                                <select asp-for="Lead.SourceId"
                                        class="form-select form-select-sm"
                                        asp-items="Model.Sources">

                                    <option value="">Select Source</option>

                                </select>

                            </div>


                            <!-- Status -->
                            <div class="col-lg-3">

                                <label class="form-label fw-semibold small text-muted">Status</label>

                                <select asp-for="Lead.StatusId"
                                        class="form-select form-select-sm"
                                        asp-items="Model.Statuses"
                                        id="statusSelect">

                                    <option value="">Select Status</option>

                                </select>

                            </div>


                            <!-- Activity -->
                            <div class="col-lg-3">

                                <label class="form-label fw-semibold small text-muted">
                                    Activity
                                    <a href="#" id="addStatusActivityBtn" class="ms-1 small text-primary">+ New</a>
                                </label>

                                <select asp-for="Lead.ActivityId"
                                        class="form-select form-select-sm"
                                        asp-items="Model.StatusActivities"
                                        id="StatusActivitySelect">

                                    <option value="">Select Activity</option>

                                </select>

                            </div>


                            <!-- Assigned User -->
                            <div class="col-lg-3">

                                <label class="form-label fw-semibold small text-muted">Assigned User</label>

                                <select asp-for="Lead.AssignedUserId"
                                        class="form-select form-select-sm"
                                        asp-items="Model.Users">

                                    <option value="">Select User</option>

                                </select>

                            </div>


                            <!-- Attach Files -->
                            <div class="col-lg-3">

                                <label class="form-label fw-semibold small text-muted">Attach Files</label>

                                <input type="file"
                                       name="files"
                                       class="form-control form-control-sm"
                                       multiple>

                            </div>


                            <!-- Priority -->
                            <div class="col-lg-3">

                                <label class="form-label fw-semibold small text-muted">Priority</label>

                                <div class="btn-group w-100" role="group">

                                    <button type="button"
                                            class="btn btn-outline-danger btn-sm priority-btn"
                                            data-val="Hot">
                                        🔥 Hot
                                    </button>

                                    <button type="button"
                                            class="btn btn-outline-warning btn-sm priority-btn"
                                            data-val="Warm">
                                        ☀ Warm
                                    </button>

                                    <button type="button"
                                            class="btn btn-outline-success btn-sm priority-btn"
                                            data-val="Cold">
                                        ❄ Cold
                                    </button>

                                </div>

                                <input asp-for="Lead.Priority" type="hidden" id="priorityHidden" />

                            </div>


                            <!-- Activity Type -->
                            <div class="col-12">

                                <label class="form-label fw-semibold small text-muted">Activity Type</label>

                                <div class="d-flex flex-wrap gap-2">

                                    <input type="radio" class="btn-check" id="catPhone" value="Phone" asp-for="Lead.ActivityType">
                                    <label class="btn btn-outline-danger btn-sm" for="catPhone">
                                        <i class="bi bi-telephone-fill me-1"></i> Phone
                                    </label>

                                    <input type="radio" class="btn-check" id="catEmail" value="Email" asp-for="Lead.ActivityType">
                                    <label class="btn btn-outline-primary btn-sm" for="catEmail">
                                        <i class="bi bi-envelope-fill me-1"></i> Email
                                    </label>

                                    <input type="radio" class="btn-check" id="catMeeting" value="Meeting" asp-for="Lead.ActivityType">
                                    <label class="btn btn-outline-success btn-sm" for="catMeeting">
                                        <i class="bi bi-people-fill me-1"></i> Meeting
                                    </label>

                                    <input type="radio" class="btn-check" id="catDemo" value="Demo" asp-for="Lead.ActivityType">
                                    <label class="btn btn-outline-info btn-sm" for="catDemo">
                                        <i class="bi bi-play-fill me-1"></i> Demo
                                    </label>

                                </div>

                            </div>

                            <!-- Follow Up Section -->
                            <div class="col-12 border-top pt-4">

                                <div class="row g-4">

                                    <div class="col-lg-4">

                                        <label class="form-label fw-semibold small text-muted">
                                            Follow Up <span class="text-danger">*</span>
                                        </label>

                                        <input asp-for="Lead.FollowUpDate"
                                               type="date"
                                               class="form-control form-control-sm">

                                    </div>


                                    <div class="col-lg-4">

                                        <label class="form-label fw-semibold small text-muted">Time</label>

                                        <input asp-for="Lead.FollowUpTime"
                                               type="time"
                                               class="form-control form-control-sm">

                                    </div>


                                    <div class="col-lg-4">

                                        <label class="form-label fw-semibold small text-muted">Expected Closure</label>

                                        <input asp-for="Lead.ExpectedClosureDate"
                                               type="date"
                                               class="form-control form-control-sm">
                                    </div>

                                </div>

                            </div>


                            <!-- Qualification Section -->
                            <div class="col-12 border-top pt-4">

                                <div class="row g-4">

                                    <div class="col-lg-2">

                                        <div class="form-check mt-4">

                                            <input asp-for="Lead.IsQualified"
                                                   class="form-check-input"
                                                   type="checkbox">

                                            <label class="form-check-label fw-semibold small">
                                                Qualified
                                            </label>

                                        </div>

                                    </div>


                                    <div class="col-lg-4">

                                        <label class="form-label fw-semibold small text-muted">
                                            Qualification Notes
                                        </label>

                                        <input asp-for="Lead.QualificationNotes"
                                               class="form-control form-control-sm">

                                    </div>


                                    <div class="col-lg-2">

                                        <label class="form-label fw-semibold small text-muted">
                                            Budget
                                        </label>

                                        <input asp-for="Lead.Budget"
                                               class="form-control form-control-sm">

                                    </div>


                                    <div class="col-lg-2">

                                        <label class="form-label fw-semibold small text-muted">
                                            Decision Date
                                        </label>

                                        <input asp-for="Lead.DecisionDate"
                                               type="date"
                                               class="form-control form-control-sm">

                                    </div>


                                    <div class="col-lg-2">

                                        <label class="form-label fw-semibold small text-muted">
                                            Probability %
                                        </label>

                                        <input asp-for="Lead.Probability"
                                               type="number"
                                               min="0"
                                               max="100"
                                               class="form-control form-control-sm">

                                    </div>

                                </div>

                            </div>

                        </div>
                    </div>
                </div>
            </div>


            <!-- Comments & Notes Tab -->
            <div class="tab-pane fade" id="commentsTab" role="tabpanel" aria-labelledby="comments-tab">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white py-2 d-flex justify-content-between align-items-center">
                        <span class="small fw-bold text-muted text-uppercase">Comments & Notes</span>
                        <select id="commentTemplate" class="form-select form-select-sm w-auto border-0 text-primary fw-bold">
                            <option value="">Quick Templates</option>
                            @foreach (var t in (Model.CommentTemplates as SelectList ?? new SelectList(Enumerable.Empty<SelectListItem>())))
                            {
                                <option value="@t.Value">@t.Text</option>
                            }
                        </select>
                    </div>
                    <div class="card-body p-0">
                        <textarea id="comments" name="Comments" class="form-control border-0 rounded-0" rows="8" placeholder="Type notes here..."></textarea>
                    </div>
                </div>
            </div>



            <!-- for user right -->
            <div class="tab-pane fade" id="RightsTab" role="tabpanel">

                <h6 class="text-uppercase fw-bold text-secondary mb-3">User Rights</h6>

                <!-- Add User Rights -->
                <div class="card shadow-sm mb-3">
                    <div class="card-body">

                        <div class="row g-2 align-items-end">

                            <div class="col-md-4">
                                <label class="form-label small fw-semibold">Select User</label>
                                <select id="userSelect" class="form-select form-select-sm"
                                        asp-items="Model.Users">
                                    <option value="">Select User</option>
                                </select>
                            </div>

                            <div class="col-md-2">
                                <div class="form-check mt-4">
                                    <input class="form-check-input" type="checkbox" id="canView">
                                    <label class="form-check-label">View</label>
                                </div>
                            </div>

                            <div class="col-md-2">
                                <div class="form-check mt-4">
                                    <input class="form-check-input" type="checkbox" id="canEdit">
                                    <label class="form-check-label">Edit</label>
                                </div>
                            </div>

                            <div class="col-md-2">
                                <button type="button" class="btn btn-primary btn-sm mt-3" id="addUserRight">
                                    Add
                                </button>
                            </div>

                        </div>

                    </div>
                </div>

                <!-- Rights Table -->
                <table class="table table-sm table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>User</th>
                            <th>Can View</th>
                            <th>Can Edit</th>
                            <th width="100">Actions</th>
                        </tr>
                    </thead>

                    <tbody id="rightsTableBody">

                        @{
                            var existingRights = Model.UserLeadRights ?? new List<UserLeadRightsViewModel>();
                            for (int ri = 0; ri < existingRights.Count; ri++)
                            {
                                var r = existingRights[ri];
                                <tr data-index="@ri">
                                    <td>
                                        @r.UserName
                                        <input type="hidden" name="UserLeadRights[@ri].Id" value="@r.Id" />
                                        <input type="hidden" name="UserLeadRights[@ri].UserId" value="@r.UserId" />
                                        <input type="hidden" name="UserLeadRights[@ri].LeadId" value="@r.LeadId" />
                                    </td>
                                    <td>
                                        @(r.CanView ? "✔️" : "❌")
                                        <input type="hidden" name="UserLeadRights[@ri].CanView" value="@r.CanView" />
                                    </td>
                                    <td>
                                        @(r.CanEdit ? "✔️" : "❌")
                                        <input type="hidden" name="UserLeadRights[@ri].CanEdit" value="@r.CanEdit" />
                                    </td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-danger remove-right">Remove</button>
                                    </td>
                                </tr>
                            }
                        }

                    </tbody>

                </table>

            </div>

            <!-- Product Details Tab -->
            <div class="tab-pane fade" id="productTab" role="tabpanel" aria-labelledby="product-tab">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="text-uppercase fw-bold text-secondary mb-0"
                        style="font-size: 0.8rem; letter-spacing: 1px;">
                        Product Details
                    </h6>
                    <div>
                        <button type="button" class="btn btn-success btn-sm px-3 shadow-sm" id="addProduct">
                            <i class="bi bi-plus-lg"></i> Add Row
                        </button>
                        <button type="button" class="btn btn-primary btn-sm add-product-btn " id="addNewProduct">
                            <i class="bi bi-plus-lg"></i> Add New Product
                        </button>
                    </div>
                </div>

                <div class="table-responsive shadow-sm rounded border bg-white mb-4">
                    <table class="table table-sm table-hover align-middle mb-0" id="productTable" style="min-width: 1200px;">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th style="width: 180px;">Product Name</th>
                                <th class="ps-3" style="width: 140px;">Category</th>
                                <th class="ps-3" style="width: 140px;">Pro.Group</th>
                                <th class="text-center" style="width: 70px;">Qty</th>
                                <th class="text-end" style="width: 100px;">Price</th>
                                <th class="text-end" style="width: 100px;">Sale Val</th>
                                <th class="text-center" style="width: 80px;">Tax %</th>
                                <th class="text-end" style="width: 100px;">Tax Val</th>
                                <th class="text-end" style="width: 110px;">Total</th>
                                <th class="text-end" style="width: 100px;">Cost</th>
                                <th class="text-end" style="width: 100px;">Profit</th>
                                <th style="width: 40px;"></th>
                            </tr>
                        </thead>
                        <tbody id="productBody">
                            <tr class="product-row">
                                <td>
                                    <div class="d-flex gap-1 align-items-center">
                                        <input list="productList"
                                               class="form-control form-control-sm border-0 bg-transparent fw-bold text-primary product-name"
                                               placeholder="Type product name..." name="Lead.ProductItems[0].ProductName" />
                                        <input type="hidden" class="product-id" name="Lead.ProductItems[0].ProductId" />
                                    </div>
                                </td>
                                <td>
                                    <input type="text" class="form-control form-control-sm category" readonly name="Lead.ProductItems[0].CategoryName" />
                                    <input type="hidden" class="category-id" name="Lead.ProductItems[0].CategoryId" />
                                </td>
                                <td>
                                    <input type="text" class="form-control form-control-sm productgroup" readonly name="Lead.ProductItems[0].ProductGroup" />
                                </td>
                                <td><input type="number" class="form-control form-control-sm border-0 bg-transparent text-center qty" name="Lead.ProductItems[0].Quantity" value="1" /></td>
                                <td><input type="number" class="form-control form-control-sm border-0 bg-transparent text-end unitprice" name="Lead.ProductItems[0].UnitPrice" value="0" /></td>
                                <td><input type="text" class="form-control form-control-sm border-0 bg-light text-end salevalue" name="Lead.ProductItems[0].SaleValue" readonly /></td>
                                <td><input type="number" class="form-control form-control-sm border-0 bg-transparent text-center taxpct" name="Lead.ProductItems[0].TaxPercentage" value="0" readonly /></td>
                                <td><input type="text" class="form-control form-control-sm border-0 bg-light text-end taxvalue" name="Lead.ProductItems[0].TaxValue" readonly /></td>
                                <td><input type="text" class="form-control form-control-sm border-0 bg-light text-end fw-bold gtotal" name="Lead.ProductItems[0].GrossTotal" readonly /></td>
                                <td><input type="number" class="form-control form-control-sm border-0 bg-transparent text-end cost" name="Lead.ProductItems[0].Cost" value="0" readonly /></td>
                                <td><input type="text" class="form-control form-control-sm border-0 bg-light text-end fw-bold grossprofit" name="Lead.ProductItems[0].GrossProfit" readonly /></td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-link text-danger p-0 remove-row"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Totals -->
                <div class="row mb-4">
                    <div class="col-md-8"></div>
                    <div class="col-md-4">
                        <div class="card p-2 shadow-sm">
                            <div class="d-flex justify-content-between small text-muted mb-1"><div>Subtotal</div><div id="leadSubtotal">0.00</div></div>
                            <div class="d-flex justify-content-between small text-muted mb-1"><div>Tax Total</div><div id="leadTaxTotal">0.00</div></div>
                            <div class="d-flex justify-content-between small text-muted mb-1"><div>Total Cost</div><div id="leadTotalCost">0.00</div></div>
                            <div class="d-flex justify-content-between fw-bold"><div>Gross Total</div><div id="leadGrossTotal">0.00</div></div>
                            <div class="d-flex justify-content-between small text-muted mt-2"><div>Gross Profit</div><div id="leadGrossProfit">0.00</div></div>
                        </div>
                    </div>
                </div>

                <!-- Hidden aggregate inputs for model binding -->
                <input type="hidden" name="Lead.SubTotal" />
                <input type="hidden" name="Lead.TaxTotal" />
                <input type="hidden" name="Lead.TotalCost" />
                <input type="hidden" name="Lead.GrossProfit" />

                <datalist id="productList">
                    @foreach (var p in Model.ProductList)
                    {
                        <option value="@p.Text" data-id="@p.Value" data-category="@p.Category" data-progroup="@p.ProGroup"></option>
                    }
                </datalist>
            </div>
        </div>

        <!-- Hidden container for selected activities (will be populated by JS) -->
        <div id="selectedActivitiesContainer"></div>

        <!-- Hidden inputs for selected activities (client will add Lead.SelectedActivities[n]) -->
        <div id="selectedActivitiesInputs"></div>

     </div>
 </form>

<!-- Create Products -->
<div class="modal fade" id="addProductModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Add New Product</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="mb-2">
                    <label>Product Name</label>
                    <input type="text" id="newProductName" class="form-control">
                </div>

                <div class="mb-2">
                    <label>Category</label>
                    <select id="newProductCategory" class="form-select form-select-sm"
                            asp-items="Model.Categories">
                        <option value="">Select Category</option>
                    </select>
                </div>

                <div class="mb-2">
                    <label>Pro.Group</label>
                    <select id="newPro_Group" class="form-select form-select-sm"
                            asp-items="Model.Pro_Groups">
                        <option value="">Select Pro.Group</option>
                    </select>
                </div>


                <div class="mb-2">
                    <label>Cost</label>
                    <input type="number" id="newProductCost" class="form-control">
                </div>

                <div class="mb-2">
                    <label>Tax %</label>
                    <input type="number" id="newProductTax" class="form-control">
                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>

                <button class="btn btn-primary" id="saveNewProduct">Save Product</button>

            </div>

        </div>
    </div>
</div>

<!-- Create Individual Contact Modal -->
<div class="modal fade" id="createContactModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Create Individual Contact</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="mb-2">
                    <label class="form-label">Name</label>
                    <input type="text" id="contactName" class="form-control form-control-sm" />
                </div>

                <div class="mb-2">
                    <label class="form-label">Phone</label>
                    <input type="text" id="contactPhone" class="form-control form-control-sm" />
                </div>

                <div class="mb-2">
                    <label class="form-label">Email</label>
                    <input type="email" id="contactEmail" class="form-control form-control-sm" />
                </div>

                <div class="mb-2">
                    <label class="form-label">Location</label>
                    <input type="text" id="contactLocation" class="form-control form-control-sm" />
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-sm btn-primary" id="saveContactBtn">Save Contact</button>
            </div>

        </div>
    </div>
</div>

<!-- Modal to create a new activity name for selected status -->
<div class="modal fade" id="addActivityModal" tabindex="-1" aria-labelledby="addActivityModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addActivityModalLabel">Add Activity for Status</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Status</label>
                    <input type="text" id="modalStatusName" class="form-control" readonly />
                </div>
                <div class="mb-3">
                    <label class="form-label">Activity Name</label>
                    <input type="text" id="newActivityName" class="form-control" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" id="saveActivityBtn" class="btn btn-primary">Save Activity</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Pass server-side data and URLs to external script via global config object
        window.leadsCreateConfig = {
            productsMap: @Html.Raw(Model.ProductsJson ?? "{}"),
            initialItems: @Html.Raw(JsonSerializer.Serialize(Model.Lead.ProductItems ?? new System.Collections.Generic.List<seashore_CRM.BLL.DTOs.LeadProductDto>())),
            initialPriority: @Html.Raw(JsonSerializer.Serialize(Model.Lead.Priority)),
            initialActivityType: @Html.Raw(JsonSerializer.Serialize(Model.Lead.ActivityType)),
            initialSelectedActivities: @Html.Raw(JsonSerializer.Serialize(Model.Lead.SelectedActivities ?? new System.Collections.Generic.List<string>())),
            urls: {
                activitiesByStatus: '@Url.Action("ActivitiesByStatus", "Leads")',
                addStatusActivity: '@Url.Action("AddStatusActivity", "Leads")',
                contactsByCompany: '@Url.Action("ContactsByCompany", "Leads")',
                productGroupsByCategory: '@Url.Action("ProductGroupsByCategory", "Leads")',
                quickCreateProduct: '@Url.Action("QuickCreate", "Products")',
                createIndividualContact: '@Url.Action("CreateIndividual", "Contacts")',
                getProductDetails: '@Url.Action("GetProductDetails", "Products")'
            }
        };
    </script>
    <script src="/js/leads-create.js"></script>
}