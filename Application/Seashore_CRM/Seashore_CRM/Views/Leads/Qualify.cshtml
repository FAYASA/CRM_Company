@model seashore_CRM.BLL.DTOs.LeadDto

@{
    ViewData["Title"] = "Qualify Lead";
}

@await Html.PartialAsync("_PageHeader")

<div class="card mx-auto" style="max-width:1000px;">
    <div class="card-body">
        <h4 class="mb-3">Qualify Lead</h4>
        <form id="qualifyForm" asp-action="Qualify" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="mb-3 form-check">
                <input asp-for="IsQualified" class="form-check-input" />
                <label asp-for="IsQualified" class="form-check-label">Qualified</label>
            </div>

            <div class="mb-3">
                <label asp-for="QualifiedOn" class="form-label"></label>
                <input asp-for="QualifiedOn" class="form-control" type="datetime-local" />
            </div>

            <div class="mb-3">
                <label asp-for="QualifiedById" class="form-label"></label>
                <select asp-for="QualifiedById" class="form-control" asp-items="ViewBag.Users">
                    <option value="">-- Select User --</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="QualificationNotes" class="form-label"></label>
                <textarea asp-for="QualificationNotes" class="form-control"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="Budget" class="form-label"></label>
                <input asp-for="Budget" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="DecisionDate" class="form-label"></label>
                <input asp-for="DecisionDate" class="form-control" type="date" />
            </div>

            <div class="mb-3">
                <label asp-for="Probability" class="form-label"></label>
                <input asp-for="Probability" class="form-control" type="number" min="0" max="100" />
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="LeadType" class="form-label"></label>
                    <input asp-for="LeadType" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="StatusId" class="form-label">Status</label>
                    <select asp-for="StatusId" class="form-select" asp-items="ViewBag.Statuses"></select>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Qualification</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var form = document.getElementById('qualifyForm');
            if (!form) return;
            form.addEventListener('submit', function (e) {
                e.preventDefault();
                var submitBtn = form.querySelector('button[type="submit"]');
                if (submitBtn) submitBtn.disabled = true;

                var formData = new FormData(form);

                fetch(form.action, {
                    method: form.method || 'POST',
                    body: formData,
                    credentials: 'same-origin',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(function(response) {
                    if (!response.ok) throw new Error('Request failed');
                    // response.url will be the final URL after any server redirect
                    var finalUrl = response.url || window.location.href;

                    if (finalUrl.indexOf('/Opportunities/Details') !== -1) {
                        // open opportunity in new tab and show success message
                        window.open(finalUrl, '_blank');
                        var alertDiv = document.createElement('div');
                        alertDiv.className = 'alert alert-success mt-3';
                        alertDiv.innerText = 'Lead qualified and converted to an Opportunity. The opportunity has been opened in a new tab.';
                        form.parentNode.insertBefore(alertDiv, form);
                        // option: redirect to lead details after short delay
                        setTimeout(function() {
                            window.location.href = '/Leads/Details/' + formData.get('Id');
                        }, 2000);
                    } else {
                        // navigate to returned page (likely lead details)
                        window.location.href = finalUrl;
                    }
                })
                .catch(function(err) {
                    if (submitBtn) submitBtn.disabled = false;
                    console.error(err);
                    var alertDiv = document.createElement('div');
                    alertDiv.className = 'alert alert-danger mt-3';
                    alertDiv.innerText = 'Unable to save qualification. Please try again.';
                    form.parentNode.insertBefore(alertDiv, form);
                });
            });
        })();
    </script>
}