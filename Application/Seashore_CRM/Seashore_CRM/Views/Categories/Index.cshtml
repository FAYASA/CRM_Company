@model IEnumerable<Seashore_CRM.ViewModels.Category.CategoryListViewModel>

@{
    ViewData["Title"] = "Categories";
}

<div class="container-fluid px-3">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center py-3">
        <div>
            <nav aria-label="breadcrumb" class="small mb-2">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a asp-action="Index" class="text-decoration-none">Home</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">Categories</li>
                </ol>
            </nav>
            <h1 class="h4 fw-bold mb-0 text-dark">
                <i class="bi bi-diagram-3 me-2"></i> Categories
                <span class="badge bg-light text-muted fw-normal ms-2 fs-6">
                    @Model.Count() total
                </span>
            </h1>
            <p class="small text-muted mb-0">
                Manage all product categories in the system
            </p>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Create" class="btn btn-danger btn-sm mb-2 px-3">
                <i class="bi bi-plus-lg me-1"></i> New Category
            </a>
        </div>
    </div>

    <!-- Categories Table -->
    <div class="table-responsive">
        <table class="table table-striped table-hover table-bordered align-middle bg-white">
            <thead class="table-secondary small text-uppercase">
                <tr>
                    <th><i class="bi bi-tag me-1"></i> Name</th>
                    <th><i class="bi bi-toggle-on me-1"></i> Status</th>
                    <th style="width:120px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td class="fw-semibold">
                            <a asp-action="Details" asp-route-id="@c.Id" class="text-decoration-none">
                                @c.CategoryName
                            </a>
                        </td>
                        <td>
                            @if (c.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm" role="group">
                                @* <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-outline-secondary" title="View">
                                    <i class="bi bi-eye"></i>
                                </a> *@
                                <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-outline-primary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @* <a asp-action="Delete" asp-route-id="@c.Id" class="btn btn-outline-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a> *@
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>